# .env.example
# Copy this file to .env and fill in real values.
# This file is committed (no real secrets here).
# Usage: cp .env.example .env

# HuggingFace 
# Your HF access token — generate at https://huggingface.co/settings/tokens
# Scope required: read
HF_TOKEN=hf_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Data Paths
# Root directory for all local data (raw docs, chunks, indices)
# On HF Spaces persistent storage: /data
# Local development: ./data  (gitignored)
DATA_DIR=./data

# Raw downloaded documents directory (populated by scripts/download_corpus.py)
RAW_DOCS_DIR=./data/raw

# Processed chunks directory (populated by corpus/chunker.py)
CHUNKS_DIR=./data/chunks

# Index directory (populated by scripts/build_index.py)
INDEX_DIR=./data/indices

# Index File Paths
# BM25 index (pickle file, ~50MB for Phase 1 corpus)
BM25_INDEX_PATH=./data/indices/bm25_index.pkl

# FAISS index (binary file, ~25MB for Phase 1 corpus at 1024 dims)
FAISS_INDEX_PATH=./data/indices/faiss_index.index

# Chunk metadata companion to FAISS index (JSON, maps int IDs to metadata)
FAISS_ID_MAP_PATH=./data/indices/faiss_id_map.json

# Corpus registry (JSON manifest of all ingested documents)
CORPUS_REGISTRY_PATH=./data/chunks/corpus_registry.json

# Hardware
# Compute device: "cuda" | "cpu" | "auto" (auto = use CUDA if available)
DEVICE=auto

# Logging
# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Pipeline Hyperparameters 
# These can be overridden here without touching settings.py
# BM25 top-k per sub-query
BM25_TOP_K=20

# FAISS top-k per sub-query
FAISS_TOP_K=20

# Number of candidates passed from RRF to cross-encoder reranker
RERANKER_INPUT_K=20

# Number of top chunks passed to the generator
GENERATOR_CONTEXT_K=5

# RRF smoothing constant k (default 60, from Cormack et al. 2009)
RRF_K=60